{
  "name": "auth-demo",
  "version": "0.0.1",
  "description": "Comprehensive authentication demo showcasing flows-auth state machine and branded components",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "vite dev --host dev.thepia.net --port 5187",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/smoke.test.js"
  },
  "dependencies": {
    "@thepia/branding": "^1.5.2",
    "@thepia/flows-auth": "workspace:*",
    "@xyflow/svelte": "0.1.30",
    "d3": "^7.9.0",
    "phosphor-svelte": "^2.0.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.3.2",
    "@playwright/test": "^1.55.0",
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/adapter-static": "^3.0.9",
    "@sveltejs/kit": "~2.57.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.1.10",
    "@types/d3": "^7.4.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.16",
    "svelte": "^5.0.0",
    "svelte-check": "^4.4.0",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.5.0",
    "vite": "^5.4.4"
  }
}
