{
  "name": "flows-app-demo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "predev": "npm run build:tokens",
    "dev": "vite dev",
    "dev:auto": "./scripts/dev-with-api-detection.sh",
    "dev:local": "./scripts/dev-with-api-detection.sh --local-api",
    "dev:production": "./scripts/dev-with-api-detection.sh --production-api",
    "build": "npm run build:tokens && vite build",
    "build:tokens": "node src/branding/build-tokens.js",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.5.27",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/eslint": "^9.6.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.45.1",
    "globals": "^15.0.0",
    "prettier": "^3.1.1",
    "prettier-plugin-svelte": "^3.2.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.4.0",
    "tslib": "^2.4.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.4"
  },
  "dependencies": {
    "@thepia/branding": "^1.5.5",
    "@thepia/flows-auth": "workspace:*"
  }
}
