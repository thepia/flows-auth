{
  "name": "tasks-app-demo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "concurrently -n lib,demo -c magenta,blue \"pnpm --filter @thepia/flows-auth build:watch\" \"vite dev --port 5176\"",
    "dev:app": "vite dev --port 5176",
    "dev:https": "concurrently -n lib,demo -c magenta,blue \"pnpm --filter @thepia/flows-auth build:watch\" \"vite dev --port 5176 --https --host\"",
    "dev:https:app": "vite dev --port 5176 --https --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "concurrently": "^9.0.0",
    "@sveltejs/kit": "~2.57.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.0.0",
    "@types/eslint": "^9.6.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.45.1",
    "globals": "^15.0.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.1.1",
    "prettier-plugin-svelte": "^3.2.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.4.0",
    "tslib": "^2.4.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.1.5",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@thepia/branding": "^1.5.2",
    "@thepia/flows-auth": "workspace:*"
  }
}
