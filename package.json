{
  "name": "@thepia/flows-auth",
  "version": "1.2.0",
  "description": "Svelte authentication library with WebAuthn/passkey support for Thepia Flow applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./dev": {
      "types": "./dist/svelte/dev.d.ts",
      "svelte": "./dist/svelte/dev.js",
      "default": "./dist/svelte/dev.js"
    },
    "./style.css": "./dist/flows-auth.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "svelte.config.js",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:watch": "node scripts/build-watch.mjs",
    "build:paraglide": "node scripts/build-paraglide.mjs",
    "test": "vitest run --exclude '**/tests/integration/**' && vitest run tests/integration --no-file-parallelism",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --coverage --exclude 'tests/{integration/**,critical/**,package/**}'",
    "test:unit": "vitest run tests/stores/ tests/utils/ tests/api/ tests/components/",
    "test:integration": "vitest run tests/integration/",
    "test:critical": "vitest run tests/critical/ tests/contracts/ tests/unit/response-processing.test.ts tests/unit/ui-ux-integration.test.ts",
    "test:smoke": "vitest run tests/stores/auth-state-machine.test.ts tests/integration/api-environment.test.ts",
    "test:package": "vitest run tests/package",
    "test:paraglide-merge": "vitest run tests/integration/paraglide-multi-directory-merge.test.ts",
    "test:demos": "pnpm test:demos:auth && pnpm test:demos:flows-app",
    "test:demos:auth": "cd examples/auth-demo && pnpm build",
    "test:demos:flows-app": "cd examples/flows-app-demo && pnpm build",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tests/tsconfig.json",
    "svelte:check": "svelte-check --tsconfig ./tsconfig.json",
    "prepublishOnly": "npm run build",
    "publish:npm": "dotenv -- bash -c 'npm publish --registry https://npm.pkg.github.com --//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}'",
    "publish:pnpm": "dotenv -- bash -c 'pnpm publish --registry https://npm.pkg.github.com --//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}'",
    "publish:npm:dry": "dotenv -- bash -c 'npm publish --dry-run --registry https://npm.pkg.github.com --//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}'",
    "publish:pnpm:dry": "dotenv -- bash -c 'pnpm publish --dry-run --registry https://npm.pkg.github.com --//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}'",
    "pre-commit": "./scripts/pre-commit-validation.sh",
    "pre-push": "./scripts/pre-push-sanity-check.sh",
    "pre-push:quick": "./scripts/pre-push-sanity-check.sh --skip-build",
    "pre-push:fast": "./scripts/pre-push-sanity-check.sh --skip-tests --skip-build",
    "validate": "pnpm typecheck && pnpm check && pnpm test",
    "validate:quick": "pnpm typecheck && pnpm test:smoke",
    "validate:publish": "pnpm build && pnpm test:package",
    "verify-auth-patterns": "pnpm test:critical && echo '✅ Authentication patterns verified'",
    "protect-auth": "pnpm test:critical && pnpm typecheck && pnpm build",
    "example:tasks-app-demo": "cd examples/tasks-app-demo && pnpm dev",
    "example:flows-app-demo": "cd examples/flows-app-demo && pnpm dev",
    "example:flows-app-demo:local": "cd examples/flows-app-demo && pnpm dev:local",
    "example:flows-app-demo:production": "cd examples/flows-app-demo && pnpm dev:production"
  },
  "keywords": [
    "svelte",
    "authentication",
    "webauthn",
    "passkeys",
    "flows",
    "oauth",
    "thepia"
  ],
  "author": "Thepia <dev@thepia.com>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/thepia/flows-auth"
  },
  "bugs": {
    "url": "https://github.com/thepia/flows-auth/issues"
  },
  "homepage": "https://github.com/thepia/flows-auth#readme",
  "peerDependencies": {
    "@thepia/branding": "^1.5.5",
    "@xyflow/svelte": "0.1.30",
    "d3": "^7.0.0",
    "phosphor-svelte": "^2.0.0 || ^3.0.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@thepia/branding": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@xyflow/svelte": {
      "optional": true
    },
    "d3": {
      "optional": true
    },
    "phosphor-svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@inlang/paraglide-js": "^2.3.2",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.0.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "@xyflow/svelte": "0.1.30",
    "cross-env": "^7.0.3",
    "d3": "^7.9.0",
    "dotenv-cli": "^8.0.0",
    "jsdom": "^23.0.0",
    "sharp": "^0.34.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.4.0",
    "svelte-preprocess": "^6.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@simplewebauthn/browser": "^13.1.2",
    "@thepia/branding": "^1.5.5",
    "base64url": "^3.0.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "publishConfig": {
    "access": "public",
    "@thepia:registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.11.0"
}
